<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title><%= @document.filename %></title>
  <style>
    html, body { margin: 0; padding: 0; }
    img { display: block; max-width: 100%; }
  </style>
</head>
<body>
<% if @document.viewable_inline? %>
  <%= tag.img(
    src: raw_crime_application_document_path(@crime_application, @document.s3_object_key),
    alt: @document.filename
  ) %>
<% else %>
  <p class="govuk-body"><%= t('.not_embeddable') %></p>
  <%= govuk_link_to(
    sanitize(t(:download_file, scope: 'values', file_extension: @document.file_extension, file_size: number_to_human_size(@document.file_size))),
    download_crime_application_document_path(@crime_application, @document.s3_object_key)
  ) %>
<% end %>
</body>
</html>
