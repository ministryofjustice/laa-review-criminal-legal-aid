<% title t('landing.page_title') %>
<div class="govuk-width-container">
    <h1 class="govuk-heading-xl">
      <%= service_name %>
    </h1>

    <% if FeatureFlags.offline_on_bank_holidays.enabled? %>
      <p class="govuk-body">
        The service is available from <%= business_hours_start %> until <%= business_hours_end %>. It is not available on bank holidays.
      </p>
    <% else %>
      <p class="govuk-body">
        The service is available from <%= business_hours_start %> until <%= business_hours_end %>.
      </p>
    <% end %>
    <p class="govuk-body">
      Use this service to review criminal legal aid applications.
    </p>
    <p class="govuk-body">
      Only caseworkers who have received an email invitation will have access.
    </p>

  <div class="govuk-!-margin-top-9">
    <%= govuk_start_button(text: t('calls_to_action.start_now'), href: user_azure_ad_omniauth_authorize_path, as_button: true) %>
  </div>
</div>
